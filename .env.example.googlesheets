# ====================================================================
# GOOGLE SHEETS PROVIDER (NOT YET IMPLEMENTED — template only)
# ====================================================================
# Future provider for spreadsheets stored in Google Drive.
# To implement, create app/core/providers/google_sheets.py and register
# it in app/core/providers/__init__.py.
#
# Setup once implemented:
#   cp .env.example.googlesheets .env
#
# Google Cloud setup (~5 minutes, one-time):
#   1. https://console.cloud.google.com → Create / select a project
#   2. "APIs & Services" → "Library" → enable "Google Sheets API"
#   3. "Credentials" → "Create credentials" → "OAuth client ID"
#        - Application type: Web application
#        - Authorized JavaScript origins: http://localhost:8000
#        - Authorized redirect URIs: http://localhost:8000
#   4. Copy "Client ID" below
#   5. OAuth consent screen → add scope:
#        - https://www.googleapis.com/auth/spreadsheets
# ====================================================================
PROVIDER_TYPE=google_sheets

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Spreadsheet ID is the long string in the URL between /d/ and /edit:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit#gid=0
EXCEL_FILE_URL=1AbCdEfGhIjKlMnOpQrStUvWxYz1234567890ABCDEF

EXCEL_SHEET_NAME=Sheet1

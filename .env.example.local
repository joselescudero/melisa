# ====================================================================
# LOCAL FILE PROVIDER
# ====================================================================
# Use this when the Excel file lives on your local disk — including
# OneDrive / iCloud / Dropbox sync folders (they're just local paths).
#
# Setup:
#   cp .env.example.local .env
#
# Requirements:
#   - File must be .xlsx or .xlsm (NOT legacy .xls — open in Excel and
#     "Save As" .xlsx if needed).
#   - No authentication required, no popup, no Azure setup.
# ====================================================================
PROVIDER_TYPE=local

# Absolute path to the Excel file. The file:// prefix is optional.
# NOTE: openpyxl supports .xlsx and .xlsm only. If you have a legacy .xls
# file, open it in Excel and "Save As" .xlsx.
EXCEL_FILE_URL=/Users/J.ESCUDEROGONZALEZ/Library/CloudStorage/OneDrive-ZurichInsurance/JoseLuis-tmp-DemoMiguel.xlsx

EXCEL_SHEET_NAME=Sheet1

# Not used by this provider, but kept for compatibility:
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# ====================================================================
# MICROSOFT 365 PROVIDER (SharePoint / OneDrive for Business)
# ====================================================================
# Use this when the Excel file lives in SharePoint Online or OneDrive
# for Business and is accessed via a sharing link.
#
# Setup:
#   cp .env.example.m365 .env
#
# Azure AD App Registration (~2 minutes, one-time):
#   1. https://portal.azure.com → "App registrations" → "New registration"
#   2. Name: "Excel Processor"
#   3. Supported account types: "Accounts in any organizational directory"
#   4. Redirect URI: "Single-page application (SPA)" → http://localhost:8000
#   5. Register → copy the "Application (client) ID" below
#   6. "API permissions" → Add → Microsoft Graph → Delegated:
#        - Files.ReadWrite
#        - Sites.ReadWrite.All
#   7. "Grant admin consent" (or ask your admin)
# ====================================================================
PROVIDER_TYPE=microsoft365

AZURE_CLIENT_ID=your-client-id-here

# Optional. Leave empty to allow login from any M365 organization.
AZURE_TENANT_ID=

# SharePoint / OneDrive sharing URL (right-click file → "Copy link")
EXCEL_FILE_URL=https://zurichinsurance-my.sharepoint.com/:x:/r/personal/jose_luis_escudero_gonzalez_zurich_com/Documents/JoseLuis-tmp-DemoMiguel.xls?d=wf384907f05104ce1bff149b20c535892&csf=1&web=1&e=jtCDYq

EXCEL_SHEET_NAME=Sheet1
